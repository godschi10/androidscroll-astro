---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const searchData = JSON.stringify(posts.map(post => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description ?? '',
  url: `/posts/${post.id}`,
  cover: post.data.cover ?? '',
  date: post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
})));
---

<Layout title="Search">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">Search</h1>

    <input
      type="text"
      id="search-input"
      placeholder="Search posts..."
      class="w-full px-5 py-3 rounded-xl border border-neutral-200 focus:border-[#00A88F] focus:outline-none text-neutral-900 text-lg"
      autofocus
    />

    <p id="search-count" class="mt-3 text-sm text-neutral-400"></p>
    <div id="search-results" class="mt-6 flex flex-col gap-4"></div>

    <div id="all-posts" class="mt-6 flex flex-col gap-4">
      {posts.map(post => (
        <a href={`/posts/${post.id}`} class="group flex gap-4 bg-white rounded-xl border border-neutral-200 hover:border-[#00A88F] hover:shadow-md transition-all p-4">
          {post.data.cover && (
            <div class="w-24 h-20 flex-shrink-0 rounded-lg overflow-hidden">
              <img src={post.data.cover} alt={post.data.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
          )}
          <div class="flex flex-col justify-center">
            <h2 class="font-bold text-neutral-900 group-hover:text-[#00A88F] transition-colors leading-snug">{post.data.title}</h2>
            <p class="mt-1 text-xs text-neutral-400">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<script type="module" data-posts={searchData}>
  const raw = document.currentScript.getAttribute('data-posts');
  const allData = JSON.parse(raw);

  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  const allPosts = document.getElementById('all-posts');
  const count = document.getElementById('search-count');

  function search(query) {
    if (!query) {
      results.innerHTML = '';
      allPosts.style.display = 'flex';
      count.textContent = '';
      return;
    }

    allPosts.style.display = 'none';
    const q = query.toLowerCase();
    const found = allData.filter(p =>
      p.title.toLowerCase().includes(q) ||
      p.description.toLowerCase().includes(q)
    );

    count.textContent = `${found.length} result${found.length !== 1 ? 's' : ''} for "${query}"`;

    if (found.length === 0) {
      results.innerHTML = `<p class="text-neutral-500">No results found for "<strong>${query}</strong>"</p>`;
      return;
    }

    results.innerHTML = found.map(r => `
      <a href="${r.url}" class="group flex gap-4 bg-white rounded-xl border border-neutral-200 hover:border-[#00A88F] hover:shadow-md transition-all p-4">
        ${r.cover ? `<div class="w-24 h-20 flex-shrink-0 rounded-lg overflow-hidden"><img src="${r.cover}" alt="${r.title}" class="w-full h-full object-cover" loading="lazy"></div>` : ''}
        <div class="flex flex-col justify-center">
          <h2 class="font-bold text-neutral-900 group-hover:text-[#00A88F] transition-colors leading-snug">${r.title}</h2>
          <p class="mt-1 text-xs text-neutral-400">${r.date}</p>
          ${r.description ? `<p class="mt-1 text-sm text-neutral-500 line-clamp-1">${r.description}</p>` : ''}
        </div>
      </a>
    `).join('');
  }

  input.addEventListener('input', () => search(input.value.trim()));

// Auto-search from URL param
const params = new URLSearchParams(window.location.search);
const q = params.get('q');
if (q) {
  input.value = q;
  search(q);
}
</script>