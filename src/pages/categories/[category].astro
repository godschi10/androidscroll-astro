---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = [
    { slug: "guides-how-tos", name: "Guides & How-tos" },
    { slug: "tips-hidden-features", name: "Tips & Hidden Features" },
    { slug: "buying-guides", name: "Buying Guides & Recommendations" },
    { slug: "troubleshooting-fixes", name: "Troubleshooting & Fixes" },
  ];

  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .filter(p => p.data.parentCategory === cat.slug || p.data.categories?.includes(cat.slug))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={cat.name}>
  <div class="mb-8">
    <a href="/categories" class="text-sm text-[#00A88F] hover:underline">← All Categories</a>
    <h1 class="text-3xl font-bold mt-2 text-neutral-900 dark:text-neutral-100">{cat.name}</h1>
    <p class="text-neutral-500 dark:text-neutral-400 mt-1">{posts.length} articles</p>
  </div>

  {posts.length === 0 ? (
    <p class="text-neutral-500 dark:text-neutral-400">No posts in this category yet.</p>
  ) : (
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map(post => (
        <a 
          href={`/posts/${post.id}`} 
          class="group flex flex-col rounded-xl overflow-hidden bg-surface-2 border border-neutral-200 dark:border-neutral-700 hover:border-[#00A88F] dark:hover:border-[#00A88F] hover:shadow-md transition-all duration-300"
        >
          {post.data.cover ? (
            <div class="w-full h-44 overflow-hidden">
              <img src={post.data.cover} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
          ) : (
            <div class="w-full h-2 bg-gradient-to-r from-[#00A88F] to-[#008c72]"></div>
          )}
          <div class="p-5 flex flex-col flex-1">
            <h2 class="font-bold text-neutral-900 dark:text-neutral-100 group-hover:text-[#00A88F] dark:group-hover:text-[#00A88F] transition-colors leading-snug">
              {post.data.title}
            </h2>
            <p class="mt-1 text-xs text-neutral-400 dark:text-neutral-500">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </p>
            {post.data.description && (
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300 line-clamp-2 flex-1">{post.data.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  )}
</Layout>
