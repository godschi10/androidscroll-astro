---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="All Posts">
  <h1 class="text-3xl font-bold mb-8">All Posts</h1>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {posts.map(post => (
      <a href={`/posts/${post.id}`} class="group flex flex-col rounded-xl overflow-hidden bg-white border border-neutral-200 hover:border-[#00A88F] hover:shadow-md transition-all duration-300">
        {post.data.cover && (
          <div class="w-full h-44 overflow-hidden">
            <img src={post.data.cover} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        )}
        <div class="p-5">
          <h2 class="font-bold text-neutral-900 group-hover:text-[#00A88F] transition-colors">{post.data.title}</h2>
          <p class="mt-1 text-xs text-neutral-400">
            {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </p>
          {post.data.description && (
            <p class="mt-2 text-sm text-neutral-600 line-clamp-2">{post.data.description}</p>
          )}
        </div>
      </a>
    ))}
  </div>
</Layout>