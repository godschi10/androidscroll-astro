---
import '../styles/global.css';

const { 
  title, 
  description, 
  cover,
  coverAlt,
  type = 'website'
} = Astro.props;

const siteUrl = 'https://androidscroll.com';
const siteName = 'AndroidScroll';
const defaultDescription = 'Android tips, tricks and guides';
const defaultCover = `${siteUrl}/og-default.jpg`;

const metaTitle = title ? `${title} | ${siteName}` : siteName;
const metaDescription = description ?? defaultDescription;
const metaImage = cover ?? defaultCover;
const metaImageAlt = coverAlt ?? metaTitle;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Primary -->
  <title>{metaTitle}</title>
  <meta name="description" content={metaDescription} />
  <meta name="theme-color" content="#00A88F" />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={metaTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:image" content={metaImage} />
  <meta property="og:image:alt" content={metaImageAlt} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={metaTitle} />
  <meta name="twitter:description" content={metaDescription} />
  <meta name="twitter:image" content={metaImage} />
  <meta name="twitter:image:alt" content={metaImageAlt} />

  <!-- Fonts -->
  <style>
    @font-face {
      font-family: 'Space Grotesk';
      font-style: normal;
      font-weight: 700;
      font-display: swap;
      src: url('/fonts/space-grotesk-v22-latin-700.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Space Grotesk';
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src: url('/fonts/space-grotesk-v22-latin-600.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/fonts/inter-v20-latin-regular.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src: url('/fonts/inter-v20-latin-600.woff2') format('woff2');
    }
  </style>
</head>
<body class="bg-neutral-50 text-neutral-900 antialiased">
  <header class="bg-white border-b border-neutral-200 sticky top-0 z-50">
    <nav class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">
      <a href="/" class="font-heading font-bold text-xl text-[#00A88F]">AndroidScroll</a>
      <ul class="flex items-center gap-6 text-sm font-semibold uppercase tracking-wide">
        <li><a href="/posts" class="hover:text-[#00A88F] transition-colors">Posts</a></li>
        <li><a href="/categories" class="hover:text-[#00A88F] transition-colors">Categories</a></li>
      </ul>
    </nav>
  </header>

  <main class="max-w-6xl mx-auto px-5 py-10">
    <slot />
  </main>

  <footer class="border-t-4 border-[#00A88F] mt-16 py-8 text-center text-sm text-neutral-500">
    © {new Date().getFullYear()} AndroidScroll
  </footer>
</body>
</html>