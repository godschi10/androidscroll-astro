---
import '../styles/global.css';

const { 
  title, 
  description, 
  cover,
  coverAlt,
  type = 'website'
} = Astro.props;

const siteUrl = 'https://androidscroll.com';
const siteName = 'AndroidScroll';
const defaultDescription = 'Android tips, tricks and guides';
const defaultCover = `${siteUrl}/og-default.jpg`;

const metaTitle = title ? `${title} | ${siteName}` : siteName;
const metaDescription = description ?? defaultDescription;
const metaImage = cover ?? defaultCover;
const metaImageAlt = coverAlt ?? metaTitle;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Primary -->
  <title>{metaTitle}</title>
  <meta name="description" content={metaDescription} />
  <meta name="theme-color" content="#00A88F" />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={metaTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:image" content={metaImage} />
  <meta property="og:image:alt" content={metaImageAlt} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={metaTitle} />
  <meta name="twitter:description" content={metaDescription} />
  <meta name="twitter:image" content={metaImage} />
  <meta name="twitter:image:alt" content={metaImageAlt} />

  <!-- Fonts -->
  <style>
    @font-face {
      font-family: 'Space Grotesk';
      font-style: normal;
      font-weight: 700;
      font-display: swap;
      src: url('/fonts/space-grotesk-v22-latin-700.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Space Grotesk';
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src: url('/fonts/space-grotesk-v22-latin-600.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/fonts/inter-v20-latin-regular.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src: url('/fonts/inter-v20-latin-600.woff2') format('woff2');
    }
  </style>
</head>
<body class="bg-neutral-50 text-neutral-900 antialiased">

<header class="bg-white border-b border-neutral-200 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between">
    <a href="/" class="font-bold text-xl text-[#00A88F]">AndroidScroll</a>

    <div class="flex items-center gap-4">
      <!-- Search bar (hidden by default) -->
      <div id="search-bar" class="hidden items-center gap-2">
        <input
          id="nav-search"
          type="text"
          placeholder="Search..."
          class="w-48 px-3 py-1.5 text-sm rounded-lg border border-neutral-200 focus:border-[#00A88F] focus:outline-none"
        />
      </div>

      <!-- Search icon -->
      <button id="search-toggle" aria-label="Search" class="text-neutral-600 hover:text-[#00A88F] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-6 text-sm font-semibold uppercase tracking-wide">
        <li><a href="/posts" class="hover:text-[#00A88F] transition-colors">Posts</a></li>
        <li><a href="/categories" class="hover:text-[#00A88F] transition-colors">Categories</a></li>
      </ul>

      <!-- Hamburger -->
      <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
        <span class="block w-6 h-0.5 bg-neutral-900 transition-all" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-neutral-900 transition-all" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-neutral-900 transition-all" id="bar3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-neutral-100 px-5 py-4 flex flex-col gap-4">
    <a href="/posts" class="text-sm font-semibold uppercase tracking-wide hover:text-[#00A88F] transition-colors">Posts</a>
    <a href="/categories" class="text-sm font-semibold uppercase tracking-wide hover:text-[#00A88F] transition-colors">Categories</a>
    <a href="/search" class="text-sm font-semibold uppercase tracking-wide hover:text-[#00A88F] transition-colors">Search</a>
  </div>
</header>

<script>
  // Hamburger
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    bar1.classList.toggle('rotate-45');
    bar1.classList.toggle('translate-y-2');
    bar2.classList.toggle('opacity-0');
    bar3.classList.toggle('-rotate-45');
    bar3.classList.toggle('-translate-y-2');
  });

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => menu.classList.add('hidden'));
  });

  // Search toggle
  const searchToggle = document.getElementById('search-toggle');
  const searchBar = document.getElementById('search-bar');
  const navSearch = document.getElementById('nav-search');

  searchToggle.addEventListener('click', () => {
    searchBar.classList.toggle('hidden');
    searchBar.classList.toggle('flex');
    if (!searchBar.classList.contains('hidden')) {
      navSearch.focus();
    }
  });

  navSearch.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && navSearch.value.trim()) {
      window.location.href = `/search?q=${encodeURIComponent(navSearch.value.trim())}`;
    }
    if (e.key === 'Escape') {
      searchBar.classList.add('hidden');
      searchBar.classList.remove('flex');
    }
  });
</script>

  <main class="max-w-6xl mx-auto px-5 py-10">
    <slot />
  </main>

  <footer class="border-t-4 border-[#00A88F] mt-16 py-8 text-center text-sm text-neutral-500">
    © {new Date().getFullYear()} AndroidScroll
  </footer>
</body>
</html>